# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# NewsAPI.org (https://newsapi.org/register)
NEWSAPI_KEY=your_newsapi_key_here

# Reddit (https://www.reddit.com/prefs/apps → create "script" app)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=NewsTracker/1.0

# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# Finnhub (https://finnhub.io/register)
FINNHUB_KEY=your_finnhub_key

# FRED (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key

# EIA (https://www.eia.gov/opendata/register.php)
EIA_API_KEY=your_eia_api_key

# CryptoCompare (https://min-api.cryptocompare.com/)
CRYPTOCOMPARE_KEY=your_cryptocompare_key

# Database
DATABASE_PATH=./data/newstracker.db

# Schedule
MORNING_RUN_HOUR=7
EVENING_RUN_HOUR=18

# Output
OUTPUT_DIR=./data/reports
LOG_LEVEL=INFO
